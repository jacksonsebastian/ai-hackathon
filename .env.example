# ============================================================
# AI Interviewer – Model & Endpoint Configuration
# ============================================================
# LOCAL machine: Streamlit UI only (thin client)
# CLOUD machine: All AI models (Jupyter GPU environment)
# ============================================================

# ── Environment ──────────────────────────────────────────────
ENVIRONMENT=production
MODEL_PROVIDER=vllm
DEBUG=false
LOG_LEVEL=INFO

# ── Cloud Jupyter GPU Endpoint (base URL) ────────────────────
# This is the public/tunneled URL of your Jupyter Cloud GPU
# All model endpoints below are relative to this base
CLOUD_BASE_URL=http://YOUR_JUPYTER_CLOUD_IP:PORT

# ── DeepSeek-R1 (Primary LLM via vLLM) ──────────────────────
# vLLM serves DeepSeek-R1 with OpenAI-compatible API
VLLM_BASE_URL=http://YOUR_JUPYTER_CLOUD_IP:8000/v1
VLLM_MODEL=deepseek-ai/DeepSeek-R1
VLLM_MAX_TOKENS=2048
VLLM_TEMPERATURE=0.7

# ── Whisper Large V3 (Speech-to-Text) ────────────────────────
# FastAPI endpoint on cloud serving Whisper
WHISPER_API_URL=http://YOUR_JUPYTER_CLOUD_IP:8001
WHISPER_MODEL=openai/whisper-large-v3

# ── Kokoro TTS (Text-to-Speech) ──────────────────────────────
# FastAPI endpoint on cloud serving Kokoro
KOKORO_API_URL=http://YOUR_JUPYTER_CLOUD_IP:8002
KOKORO_VOICE=af_heart
KOKORO_SPEED=1.0

# ── BGE-M3 Embeddings ───────────────────────────────────────
# FastAPI endpoint on cloud serving BGE-M3
EMBEDDING_API_URL=http://YOUR_JUPYTER_CLOUD_IP:8003
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024

# ── FAISS Vector Store ───────────────────────────────────────
# FAISS runs on the cloud alongside BGE-M3
# Local app accesses it via the embedding API
FAISS_INDEX_PATH=data/faiss_index

# ── Database (Local SQLite) ──────────────────────────────────
DATABASE_PATH=data/interviews.db
